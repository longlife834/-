<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.five.mapper.CategoryMapper">

    <resultMap id="CategoryMap" type="com.five.entity.Category">
        <id property="id" column="id"/>
        <result property="name" column="name"/>
        <result property="sortOrder" column="sort_order"/>
    </resultMap>
<!--分页查询分类列表-->
    <select id="getAllCategories" resultMap="CategoryMap">
        SELECT id, name, sort_order FROM category
        WHERE 1 = 1
        <if test="keyword != null and keyword != ''">
            AND name LIKE CONCAT('%',#{keyword},'%')
        </if>
        ORDER BY sort_order ASC, id ASC
        LIMIT #{offset}, #{size}
    </select>
<!-- 统计分类总数-->
    <select id="countCategories" resultType="long">
        SELECT COUNT(*) FROM category
        WHERE 1 = 1
        <if test="keyword != null and keyword != ''">
            AND name LIKE CONCAT('%',#{keyword},'%')
        </if>
    </select>

<!--     根据 ID 查询分类-->
    <select id="getCategoryById" resultMap="CategoryMap">
        SELECT id, name, sort_order FROM category WHERE id = #{id}
    </select>
<!--根据名称查询分类-->
    <select id="getCategoryByName" resultMap="CategoryMap">
        SELECT id, name, sort_order FROM category WHERE name = #{name}
    </select>
<!-- 查询所有分类（简化版）-->
    <select id="getAllCategoriesSimple" resultMap="CategoryMap">
        SELECT id, name FROM category ORDER BY sort_order ASC, id ASC
    </select>
<!--新增分类-->
    <insert id="insertCategory" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO category(name, sort_order)
        VALUES(#{name}, #{sortOrder})
    </insert>
<!--修改分类-->
    <update id="updateCategory">
        UPDATE category
        SET name = #{name},
            sort_order = #{sortOrder}
        WHERE id = #{id}
    </update>
<!--删除分类-->
    <delete id="deleteCategory">
        DELETE FROM category WHERE id = #{id}
    </delete>

</mapper>
