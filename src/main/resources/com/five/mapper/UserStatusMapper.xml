<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.five.mapper.UserStatusMapper">
<!--  检查用户是否启用 用户登录时检查账号是否被禁用或删除 -->
    <select id="isEnabled" resultType="int">
        SELECT COUNT(*) FROM user WHERE id = #{userId} AND enabled = 1 AND is_deleted = 0
    </select>
</mapper>
